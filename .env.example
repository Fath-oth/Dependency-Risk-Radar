# ── LLM — set ONE ────────────────────────────
# Gemini Flash (free tier: aistudio.google.com)
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-flash

# Anthropic Claude (fallback)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ─────────────────────────────────
# NVD API key (free: nvd.nist.gov/developers/request-an-api-key)
# Raises rate limit from 5 to 50 req/30s — recommended for large projects
NVD_API_KEY=

# ── Infrastructure ────────────────────────────
OUTPUT_DIR=/tmp/drr_reports
DEBUG=false
